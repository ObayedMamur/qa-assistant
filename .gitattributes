# QA Assistant - Git Attributes Configuration
# This file defines how Git handles different file types

# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Configuration files
.gitignore text eol=lf
.gitattributes text eol=lf
.distignore text eol=lf
.editorconfig text eol=lf
composer.json text eol=lf
package.json text eol=lf
readme.txt text eol=lf
LICENSE text eol=lf
CHANGELOG.md text eol=lf

# WordPress specific files
wp-config.php text eol=lf
.htaccess text eol=lf

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.rar binary
*.7z binary

# Font files
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Audio/Video files
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.wav binary

# Archive files
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary

# Exclude files from export-ignore (for git archive)
# These files won't be included when creating archives
.git* export-ignore
.distignore export-ignore
.wordpress-org/ export-ignore
.github/ export-ignore
tests/ export-ignore
build.sh export-ignore
BUILD.md export-ignore
WORKFLOWS.md export-ignore
*.md export-ignore
node_modules/ export-ignore
# vendor/ export-ignore
composer.json export-ignore
composer.lock export-ignore
package.json export-ignore
package-lock.json export-ignore
yarn.lock export-ignore
phpunit.xml export-ignore
.phpunit.result.cache export-ignore

# Language-specific settings
*.php diff=php
*.js diff=javascript
*.css diff=css

# Merge strategies for specific files
# Never merge these files, always use the version from the branch being merged into
readme.txt merge=ours
CHANGELOG.md merge=ours

# Custom diff drivers for better diffs
*.min.js binary
*.min.css binary

# Large File Storage (LFS) - if needed for large assets
# Uncomment and modify as needed
# *.psd filter=lfs diff=lfs merge=lfs -text
# *.ai filter=lfs diff=lfs merge=lfs -text
# *.sketch filter=lfs diff=lfs merge=lfs -text

# WordPress plugin specific
# Treat these as text files with specific handling
*.pot text eol=lf
*.po text eol=lf
*.mo binary

# IDE and editor files (usually ignored, but if tracked)
*.sublime-project text eol=lf
*.sublime-workspace text eol=lf
.vscode/*.json text eol=lf

# Documentation files
*.rst text eol=lf
*.adoc text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf

# Template files
*.tpl text eol=lf
*.mustache text eol=lf
*.hbs text eol=lf

# Build and deployment files
Dockerfile text eol=lf
docker-compose.yml text eol=lf
Makefile text eol=lf
Gruntfile.js text eol=lf
gulpfile.js text eol=lf
webpack.config.js text eol=lf

# Security files
.htpasswd text eol=lf

# Backup files (if accidentally committed)
*.bak binary
*.backup binary
*~ binary
